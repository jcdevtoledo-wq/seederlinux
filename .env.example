# =============================================================================
# SeederLinux — Variáveis de Ambiente (Self-Hosted)
# Arquitetura: Fastify + Prisma + PostgreSQL (3 containers)
# =============================================================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env && nano .env
#
# O script install.sh gera este arquivo automaticamente com valores seguros.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:SENHA@db:5432/seederlinux?schema=public
POSTGRES_PASSWORD=

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# Setup Token (first-time setup wizard)
# ---------------------------------------------------------------------------
SETUP_TOKEN=

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
PORT=8000
NODE_ENV=production

# ---------------------------------------------------------------------------
# Public URLs (for frontend)
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_SEEDER_MODE=full