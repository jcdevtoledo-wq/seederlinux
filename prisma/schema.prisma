// SeederLinux V3.0 - Data Model
// Aligned with Documento 03 - Modelo de Dados (v3.0)
//
// ARQUITETURA:
// - Organization = APENAS METADADOS (sem campos técnicos)
// - VariableDefinition = catálogo oficial (Documento 06)
// - OrganizationVariable = ÚNICA fonte de verdade dos valores

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum AppRole {
  admin_gap
  operador_om
  auditor
}

enum StationStatus {
  nunca
  ok
  atrasada
  registered
  online
  offline
  blocked
  decommissioned
}

enum ScriptStatus {
  rascunho
  pronto
  depreciado
}

enum ScriptCategory {
  core
  sistema
  rede
  seguranca
  usuario
  desktop
  automacao
  custom
  dns
  ntp
  proxy
  ad
  browser
  printer
  branding
}

enum OrgStatus {
  active
  inactive
  setup_pending
}

// =============================================================================
// USERS & AUTH
// =============================================================================

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  password     String
  displayName  String?
  blocked      Boolean    @default(false)
  lastLogin    DateTime?  @map("last_login")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  roles        UserRole[]

  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      AppRole
  orgSigla  String?  @map("org_sigla")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role, orgSigla])
  @@map("user_roles")
}

// =============================================================================
// ORGANIZATIONS (APENAS METADADOS - v3.0)
// =============================================================================

model Organization {
  id          String    @id @default(cuid())
  nome        String    @db.VarChar(255)
  sigla       String    @unique @db.VarChar(20)
  descricao   String?   @db.Text
  ativo       Boolean   @default(true)
  status      OrgStatus @default(active)
  cor         String    @default("oklch(0.6 0.15 200)")
  serial      Int       @default(0)
  estacoes    Int       @default(0)
  scriptsAtivos Int     @default(0) @map("scripts_ativos")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relacionamentos
  variables       OrganizationVariable[]
  stations        Station[]
  branding        BrandingConfig?
  profiles        SeederProfile[]
  browserPolicies BrowserPolicy[]
  printerProfiles PrinterProfile[]
  repositories    Repository[]

  @@map("organizations")
}

// =============================================================================
// VARIABLE CATALOG (catálogo oficial — Documento 06)
// =============================================================================

model VariableDefinition {
  id            String   @id @default(cuid())
  key           String   @unique @db.VarChar(80)
  label         String   @db.VarChar(120)
  category      String   @db.VarChar(40)        // DOMAIN, DNS, NTP, PROXY, AD, BRANDING, etc.
  description   String   @db.Text
  type          String   @default("string")     // string, boolean, integer, ip, url, array
  required      Boolean  @default(false)
  editable      Boolean  @default(true)
  oficial       Boolean  @default(true)
  defaultValue  String?  @map("default_value")
  exemplo       String?
  validation    String?                          // regex pattern (opcional)
  coreModule    String?  @map("core_module")    // Core.Domain, Core.Branding, etc.
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  values        OrganizationVariable[]

  @@index([category])
  @@map("variable_definitions")
}

// =============================================================================
// ORGANIZATION VARIABLES (ÚNICA FONTE DE VERDADE)
// =============================================================================

model OrganizationVariable {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  definitionId    String   @map("definition_id")
  value           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  definition   VariableDefinition  @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([organizationId, definitionId])
  @@index([organizationId])
  @@map("organization_variables")
}

// =============================================================================
// BRANDING
// =============================================================================

model BrandingConfig {
  orgId         String   @id @map("org_id")
  displayName   String?  @map("display_name")
  wallpaperUrl  String?  @map("wallpaper_url")
  wallpaperLogin String? @map("wallpaper_login")
  logoUrl       String?  @map("logo_url")
  greeterUrl    String?  @map("greeter_url")
  theme         String   @default("Mint-Y-Dark")
  conkyEnabled  Boolean  @default(false) @map("conky_enabled")
  conkyConfig   Json     @default("{}") @map("conky_config")
  shortcutsEnabled Boolean @default(true) @map("shortcuts_enabled")
  updatedAt     DateTime @default(now()) @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("branding_config")
}

// =============================================================================
// BROWSER POLICIES
// =============================================================================

model BrowserPolicy {
  id              String   @id @default(cuid())
  orgId           String   @map("org_id")
  browser         String
  homepage        String?
  bookmarksEnabled Boolean @default(false) @map("bookmarks_enabled")
  proxyEnabled    Boolean  @default(false) @map("proxy_enabled")
  certificatesEnabled Boolean @default(false) @map("certificates_enabled")
  telemetryDisabled Boolean @default(true) @map("telemetry_disabled")
  updatesDisabled Boolean @default(false) @map("updates_disabled")
  config         Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bookmarks    BrowserBookmark[]

  @@unique([orgId, browser])
  @@map("browser_policies")
}

model BrowserBookmark {
  id        String   @id @default(cuid())
  policyId  String   @map("policy_id")
  title     String
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  policy    BrowserPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@map("browser_bookmarks")
}

// =============================================================================
// SCRIPTS
// =============================================================================

model Script {
  id              String         @id @default(cuid())
  nome            String
  descricao       String         @default("")
  categoria       ScriptCategory @default(custom)
  versao          String         @default("1.0.0")
  serial          BigInt         @default(0)
  status          ScriptStatus   @default(rascunho)
  conteudo        String         @default("")
  variaveisUsadas String[]       @default([])
  autor           String         @default("")
  oficial         Boolean        @default(false)
  scriptType      String         @default("CUSTOM")
  checksum        String?
  compatibilidade String[]       @default(["ubuntu", "linuxmint", "debian"])
  prioidade       Int            @default(0)
  mandatario      Boolean        @default(false)
  criadoEm        DateTime       @default(now()) @map("criado_em")
  atualizadoEm    DateTime       @default(now()) @map("atualizado_em")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  profiles        SeederProfile[]

  @@map("scripts")
}

model SeederProfile {
  id                String   @id @default(cuid())
  nome              String
  descricao         String   @default("")
  scriptIds         String[] @default([])
  organizacaoOrigem String?  @map("organizacao_origem")
  publico           Boolean  @default(false)
  profileType       String   @default("standard")
  criadoEm          DateTime @default(now()) @map("criado_em")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization? @relation(fields: [organizacaoOrigem], references: [sigla])
  scripts           Script[]

  @@map("profiles_seeder")
}

// =============================================================================
// STATIONS
// =============================================================================

model Station {
  id             String        @id @default(cuid())
  hostname       String
  assetTag       String?       @map("asset_tag")
  serialNumber   String?       @map("serial_number")
  orgId          String        @map("org_id")
  ip             String        @default("")
  distro         String        @default("ubuntu")
  desktop        String        @default("GNOME")
  kernelVersion  String?       @map("kernel_version")
  serialAplicado BigInt        @default(0) @map("serial_aplicado")
  ultimoCheckin  DateTime?     @map("ultimo_checkin")
  status         StationStatus @default(registered)
  perfilAtivo    String?       @map("perfil_ativo")
  usuario        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tokens          StationToken[]
  runs            StationRun[]
  hardware        HardwareInventory?
  software        SoftwareInventory?
  networkInterfaces NetworkInterface[]
  users           StationUser[]

  @@map("stations")
}

model HardwareInventory {
  id             String   @id @default(cuid())
  stationId      String   @unique @map("station_id")
  cpuModel       String?  @map("cpu_model")
  cpuCores       Int?     @map("cpu_cores")
  memoryMb       Int?     @map("memory_mb")
  diskTotalGb    Int?     @map("disk_total_gb")
  motherboard    String?
  biosVersion    String?  @map("bios_version")
  updatedAt      DateTime @default(now()) @map("updated_at")

  station        Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@map("hardware_inventory")
}

model SoftwareInventory {
  id               String   @id @default(cuid())
  stationId        String   @unique @map("station_id")
  osName           String?  @map("os_name")
  osVersion        String?  @map("os_version")
  desktopEnv       String?  @map("desktop_env")
  kernelVersion    String?  @map("kernel_version")
  packages         Json     @default("[]")
  updatedAt        DateTime @default(now()) @map("updated_at")

  station          Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@map("software_inventory")
}

model NetworkInterface {
  id            String   @id @default(cuid())
  stationId     String   @map("station_id")
  interfaceName String   @map("interface_name")
  macAddress    String?  @map("mac_address")
  ipAddress     String?  @map("ip_address")
  gateway       String?
  dnsPrimary    String?  @map("dns_primary")
  dnsSecondary  String?  @map("dns_secondary")
  isPrimary     Boolean  @default(false) @map("is_primary")
  updatedAt     DateTime @default(now()) @map("updated_at")

  station       Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@map("network_interfaces")
}

model StationToken {
  id          String    @id @default(uuid())
  stationId   String    @map("station_id")
  tokenHash   String    @unique @map("token_hash")
  label       String    @default("agente")
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")

  station     Station   @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@map("station_tokens")
}

model StationRun {
  id             String    @id @default(uuid())
  stationId      String    @map("station_id")
  profileId      String?   @map("profile_id")
  serialAlvo     BigInt    @default(0) @map("serial_alvo")
  serialAnterior BigInt    @default(0) @map("serial_anterior")
  status         String    @default("ok")
  scriptsTotal   Int       @default(0) @map("scripts_total")
  scriptsOk      Int       @default(0) @map("scripts_ok")
  duracaoMs      Int       @default(0) @map("duracao_ms")
  agentVersion   String?   @map("agent_version")
  log            Json      @default("[]")
  startedAt      DateTime  @default(now()) @map("started_at")
  finishedAt     DateTime  @default(now()) @map("finished_at")

  station        Station   @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@map("station_runs")
}

model StationUser {
  id          String    @id @default(cuid())
  stationId   String    @map("station_id")
  username    String
  domainUser  Boolean   @default(false) @map("domain_user")
  lastLogin   DateTime? @map("last_login")
  createdAt   DateTime  @default(now())

  station     Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@map("station_users")
}

// =============================================================================
// SYSTEM CONFIG
// =============================================================================

model SystemConfig {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("system_config")
}

// =============================================================================
// AUDIT
// =============================================================================

model AuditEvent {
  id         String   @id @default(uuid())
  ts         DateTime @default(now())
  atorId     String   @map("ator_id")
  atorEmail  String?  @map("ator_email")
  orgId      String?  @map("org_id")
  categoria  String
  acao       String
  alvo       String?
  alvoId     String?  @map("alvo_id")
  detalhes   String?
  oldValor   String?  @map("old_value")
  newValor   String?  @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")

  @@index([ts])
  @@index([atorId])
  @@index([categoria])
  @@index([orgId])
  @@map("audit_events")
}

model SystemEvent {
  id         String   @id @default(cuid())
  stationId  String?  @map("station_id")
  orgId      String?  @map("org_id")
  eventType  String   @map("event_type")
  severity   String   @default("info")
  message    String
  metadata   Json     @default("{}")
  ts         DateTime @default(now())

  @@index([ts])
  @@index([stationId])
  @@index([orgId])
  @@map("system_events")
}

// =============================================================================
// JOBS & DEPLOYMENTS
// =============================================================================

model Job {
  id          String   @id @default(cuid())
  orgId       String?  @map("org_id")
  stationId   String?  @map("station_id")
  jobType     String   @map("job_type")
  payload     Json     @default("{}")
  status      String   @default("pending")
  scheduledAt DateTime @default(now()) @map("scheduled_at")
  startedAt   DateTime? @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  result      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("jobs")
}

model Deployment {
  id          String   @id @default(cuid())
  stationId   String   @map("station_id")
  profileId   String?  @map("profile_id")
  status      String   @default("pending")
  startedAt   DateTime @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  output      String?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       DeploymentTask[]

  @@map("deployments")
}

model DeploymentTask {
  id             String   @id @default(cuid())
  deploymentId   String   @map("deployment_id")
  scriptId       String   @map("script_id")
  status         String   @default("pending")
  executionOrder Int      @default(0) @map("execution_order")
  output         String?
  startedAt      DateTime? @map("started_at")
  finishedAt     DateTime? @map("finished_at")
  createdAt      DateTime @default(now())

  deployment     Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@map("deployment_tasks")
}

// =============================================================================
// FILES / STORAGE
// =============================================================================

model FileRecord {
  id          String   @id @default(cuid())
  orgId       String?  @map("org_id")
  fileType    String   @map("file_type")
  filename    String
  path        String
  checksum    String?
  size        Int?
  mimeType    String?  @map("mime_type")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("files")
}

// =============================================================================
// PRINTER PROFILES
// =============================================================================

model PrinterProfile {
  id             String   @id @default(cuid())
  orgId          String   @map("org_id")
  name           String
  cupsServer     String?  @map("cups_server")
  defaultQueue   String?  @map("default_queue")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  queues         PrinterQueue[]

  @@map("printer_profiles")
}

model PrinterQueue {
  id              String   @id @default(cuid())
  profileId       String   @map("profile_id")
  queueName       String
  location        String?
  driver          String?
  uri             String?
  isDefault       Boolean  @default(false) @map("is_default")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  printerProfile  PrinterProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("printer_queues")
}

// =============================================================================
// REPOSITORIES
// =============================================================================

model Repository {
  id          String   @id @default(cuid())
  orgId       String?  @map("org_id")
  name        String
  type        String
  url         String?
  enabled     Boolean  @default(true)
  isOfficial  Boolean  @default(false) @map("is_official")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("repositories")
}
